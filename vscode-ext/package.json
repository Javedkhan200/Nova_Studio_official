{
  "name": "nova-language",
  "displayName": "Nova",
  "description": "High-Level AI-Native Scripting Language",
  "version": "1.0.0",
  "publisher": "ArchitectJaved",
  "engines": { "vscode": "^1.60.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "nova",
      "aliases": ["Nova", "nova"],
      "extensions": [".nv", ".nova"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "nova",
      "scopeName": "source.nova",
      "path": "./syntaxes/nova.tmLanguage.json"
    }]
  }
}
